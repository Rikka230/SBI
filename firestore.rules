rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
       HELPERS
       ============================================================ */

    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function formationPath(formationId) {
      return /databases/$(database)/documents/formations/$(formationId);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function currentUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function isActiveUser() {
      return hasUserDoc()
        && currentUser().statut != 'suspendu';
    }

    function hasAnyRole(roles) {
      return isActiveUser()
        && currentUser().keys().hasAny(['role'])
        && currentUser().role in roles;
    }

    function isGod() {
      return isActiveUser()
        && currentUser().isGod == true;
    }

    function isAdmin() {
      return isActiveUser()
        && (
          currentUser().isGod == true ||
          currentUser().role == 'admin'
        );
    }

    function isTeacher() {
      return hasAnyRole(['teacher', 'prof', 'professeur', 'enseignant']);
    }

    function isStudent() {
      return hasAnyRole(['student', 'eleve', 'élève', 'etudiant', 'étudiant']);
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function changedOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function userProtectedFields() {
      return [
        'role',
        'isGod',
        'statut',
        'dateCreation',
        'createdAt',
        'formationIds',
        'formationsAcces'
      ];
    }

    function ownUserWritableFields() {
      return [
        'prenom',
        'nom',
        'email',
        'bio',
        'privateData',
        'photoURL',
        'photoOriginal',
        'photoStoragePath',
        'avatarUpdatedAt',
        'avatarStorageVersion',
        'avatarCleanupAt',
        'isOnline',
        'lastSeenAt',
        'totalConnectionTime',
        'learningProgress',
        'xp',
        'updatedAt'
      ];
    }

    function safeOwnUserUpdate(userId) {
      return isSelf(userId)
        && changedOnly(ownUserWritableFields())
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(userProtectedFields());
    }

    function currentUserHasFormationIds() {
      return currentUser().keys().hasAny(['formationIds'])
        && currentUser().formationIds is list
        && currentUser().formationIds.size() > 0;
    }

    function currentUserHasFormationsAcces() {
      return currentUser().keys().hasAny(['formationsAcces'])
        && currentUser().formationsAcces is list
        && currentUser().formationsAcces.size() > 0;
    }

    function userDataHasFormationIds(userData) {
      return userData.keys().hasAny(['formationIds'])
        && userData.formationIds is list
        && userData.formationIds.size() > 0;
    }

    function userDataHasFormationsAcces(userData) {
      return userData.keys().hasAny(['formationsAcces'])
        && userData.formationsAcces is list
        && userData.formationsAcces.size() > 0;
    }

    function sharedFormationWithCurrentUser(userData) {
      return (
          currentUserHasFormationIds()
          && userDataHasFormationIds(userData)
          && userData.formationIds.hasAny(currentUser().formationIds)
        )
        || (
          currentUserHasFormationsAcces()
          && userDataHasFormationsAcces(userData)
          && userData.formationsAcces.hasAny(currentUser().formationsAcces)
        );
    }

    function isAdminProfile(userData) {
      return userData.isGod == true
        || userData.role == 'admin';
    }

    function canReadUser(userId, userData) {
      return isAdmin()
        || isSelf(userId)
        || (
          isActiveUser()
          && !isAdminProfile(userData)
          && sharedFormationWithCurrentUser(userData)
        );
    }

    function courseHasFormations(courseData) {
      return courseData.keys().hasAny(['formations'])
        && courseData.formations is list
        && courseData.formations.size() > 0;
    }

    function courseSharedWithCurrentUser(courseData) {
      return courseHasFormations(courseData)
        && (
          (
            currentUserHasFormationIds()
            && courseData.formations.hasAny(currentUser().formationIds)
          )
          || (
            currentUserHasFormationsAcces()
            && courseData.formations.hasAny(currentUser().formationsAcces)
          )
        );
    }

    function courseTargetedToCurrentUser(courseData) {
      return courseData.keys().hasAny(['targetStudents'])
        && courseData.targetStudents is list
        && request.auth.uid in courseData.targetStudents;
    }

    function formationDocHasCurrentUser(formationId) {
      return signedIn()
        && formationId is string
        && exists(formationPath(formationId))
        && (
          (
            get(formationPath(formationId)).data.keys().hasAny(['students'])
            && get(formationPath(formationId)).data.students is list
            && request.auth.uid in get(formationPath(formationId)).data.students
          )
          || (
            get(formationPath(formationId)).data.keys().hasAny(['profs'])
            && get(formationPath(formationId)).data.profs is list
            && request.auth.uid in get(formationPath(formationId)).data.profs
          )
        );
    }

    function courseFormationAtAllowsCurrentUser(courseData, index) {
      return courseHasFormations(courseData)
        && courseData.formations.size() > index
        && formationDocHasCurrentUser(courseData.formations[index]);
    }

    function courseLinkedToReadableFormation(courseData) {
      return courseFormationAtAllowsCurrentUser(courseData, 0)
        || courseFormationAtAllowsCurrentUser(courseData, 1)
        || courseFormationAtAllowsCurrentUser(courseData, 2)
        || courseFormationAtAllowsCurrentUser(courseData, 3)
        || courseFormationAtAllowsCurrentUser(courseData, 4);
    }

    function canReadCourse(courseData) {
      return isAdmin()
        || (
          isTeacher()
          && courseData.auteurId == request.auth.uid
        )
        || (
          isActiveUser()
          && courseData.actif == true
          && (
            courseSharedWithCurrentUser(courseData)
            || courseTargetedToCurrentUser(courseData)
            || courseLinkedToReadableFormation(courseData)
          )
        );
    }

    function validTeacherCourseWrite() {
      return isTeacher()
        && request.resource.data.auteurId == request.auth.uid
        && request.resource.data.actif == false
        && request.resource.data.statutValidation in ['draft', 'pending'];
    }

    function validTeacherCourseUpdate() {
      return isTeacher()
        && resource.data.auteurId == request.auth.uid
        && request.resource.data.auteurId == resource.data.auteurId
        && request.resource.data.actif == false
        && request.resource.data.statutValidation in ['draft', 'pending'];
    }

    function currentUserHasFormationId(formationId) {
      return currentUserHasFormationIds()
        && formationId in currentUser().formationIds;
    }

    function currentUserHasFormationAccess(formationTitle) {
      return currentUserHasFormationsAcces()
        && formationTitle is string
        && formationTitle in currentUser().formationsAcces;
    }

    function isFormationStudent(formationData) {
      return formationData.keys().hasAny(['students'])
        && formationData.students is list
        && request.auth.uid in formationData.students;
    }

    function isFormationTeacher(formationData) {
      return formationData.keys().hasAny(['profs'])
        && formationData.profs is list
        && request.auth.uid in formationData.profs;
    }

    function canReadFormation(formationId, formationData) {
      return isAdmin()
        || isActiveUser();
    }

    function isDirectNotification() {
      return resource.data.keys().hasAny(['destinataireId'])
        && resource.data.destinataireId == request.auth.uid;
    }

    function isTargetStudentNotification() {
      return resource.data.keys().hasAny(['targetStudents'])
        && resource.data.targetStudents is list
        && request.auth.uid in resource.data.targetStudents;
    }

    function isAdminValidationNotification() {
      return isAdmin()
        && resource.data.type == 'course_validation';
    }

    function canReadNotification() {
      return isActiveUser()
        && (
          isAdminValidationNotification() ||
          isDirectNotification() ||
          isTargetStudentNotification()
        );
    }

    function canCreateNotification() {
      return isActiveUser()
        && (
          isAdmin() ||
          (
            isTeacher()
            && request.resource.data.type == 'course_validation'
            && request.resource.data.auteurId == request.auth.uid
            && request.resource.data.status == 'open'
          )
        );
    }

    function canDismissNotification() {
      return isActiveUser()
        && changedOnly(['dismissedBy'])
        && request.resource.data.dismissedBy is list
        && request.auth.uid in request.resource.data.dismissedBy
        && (
          !resource.data.keys().hasAny(['dismissedBy']) ||
          request.resource.data.dismissedBy.hasAll(resource.data.dismissedBy)
        );
    }

    function canResolveNotification() {
      return isAdmin()
        && changedOnly(['status', 'resolvedAt', 'resolvedBy'])
        && request.resource.data.status == 'resolved'
        && request.resource.data.resolvedBy == request.auth.uid;
    }

    function progressBelongsToCurrentUser(progressId, progressData) {
      return isSelf(progressId)
        || (
          progressData.keys().hasAny(['uid'])
          && progressData.uid == request.auth.uid
        )
        || (
          progressData.keys().hasAny(['userId'])
          && progressData.userId == request.auth.uid
        )
        || (
          progressData.keys().hasAny(['studentId'])
          && progressData.studentId == request.auth.uid
        );
    }

    function canReadProgressDoc(progressId, progressData) {
      return isAdmin()
        || (
          isActiveUser()
          && progressBelongsToCurrentUser(progressId, progressData)
        );
    }

    function canWriteProgressDoc(progressId, progressData) {
      return isAdmin()
        || (
          isActiveUser()
          && progressBelongsToCurrentUser(progressId, progressData)
        );
    }

    /* ============================================================
       PUBLIC SITE SETTINGS
       ============================================================ */

    match /settings/siteIndex {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    /* ============================================================
       USERS
       ============================================================ */

    match /users/{userId} {
      allow get, list: if canReadUser(userId, resource.data);

      allow create: if isAdmin();

      allow update: if isAdmin()
        || safeOwnUserUpdate(userId);

      allow delete: if isAdmin();
    }

    /* ============================================================
       COURSES
       ============================================================ */

    match /courses/{courseId} {
      allow get: if canReadCourse(resource.data);
      allow list: if isActiveUser();

      allow create: if isAdmin()
        || validTeacherCourseWrite();

      allow update: if isAdmin()
        || validTeacherCourseUpdate();

      allow delete: if isAdmin()
        || (
          isTeacher()
          && resource.data.auteurId == request.auth.uid
          && resource.data.actif == false
          && resource.data.statutValidation == 'draft'
        );
    }

    /* ============================================================
       FORMATIONS
       ============================================================ */

    match /formations/{formationId} {
      allow get, list: if canReadFormation(formationId, resource.data);

      allow create, update, delete: if isAdmin();
    }

    /* ============================================================
       NOTIFICATIONS
       ============================================================ */

    match /notifications/{notificationId} {
      allow get: if canReadNotification();
      allow list: if isActiveUser();

      allow create: if canCreateNotification();

      allow update: if canDismissNotification()
        || canResolveNotification();

      allow delete: if isAdmin();
    }

    /* ============================================================
       PROGRESS / TRACKING LEGACY COLLECTIONS
       ============================================================ */

    match /progress/{progressId} {
      allow get, list: if canReadProgressDoc(progressId, resource.data);
      allow create: if canWriteProgressDoc(progressId, request.resource.data);
      allow update: if canWriteProgressDoc(progressId, resource.data)
        && canWriteProgressDoc(progressId, request.resource.data);
      allow delete: if isAdmin();
    }

    match /courseProgress/{progressId} {
      allow get, list: if canReadProgressDoc(progressId, resource.data);
      allow create: if canWriteProgressDoc(progressId, request.resource.data);
      allow update: if canWriteProgressDoc(progressId, resource.data)
        && canWriteProgressDoc(progressId, request.resource.data);
      allow delete: if isAdmin();
    }

    match /quizResults/{resultId} {
      allow get, list: if canReadProgressDoc(resultId, resource.data);
      allow create: if canWriteProgressDoc(resultId, request.resource.data);
      allow update: if canWriteProgressDoc(resultId, resource.data)
        && canWriteProgressDoc(resultId, request.resource.data);
      allow delete: if isAdmin();
    }

    /* ============================================================
       FALLBACK
       ============================================================ */

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
